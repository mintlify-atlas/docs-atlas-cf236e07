  "keyFeatures": [
    "User registration and authentication with session management",
    "Geolocation-based infrastructure problem reporting",
    "Photo evidence upload (6 images per report)",
    "Interactive map view with report filtering",
    "Automatic case grouping by location and problem type",
    "Agent response system with photo and PDF attachments",
    "Multi-level problem categorization (Problem, Class, Type)",
    "Department and city-based filtering",
    "Case status tracking and management"
  ],
  "publicApiSurface": [
    "HomeController.inicio_secion - User login endpoint",
    "HomeController.nuevo_usuario - User registration endpoint",
    "ReportesController.GuardarReporte - Submit new citizen report",
    "ReportesController.consultar_reportes - Filter and query reports",
    "ReportesController.consultar_caso_x_report - Get case details with photos",
    "ReportesController.lista_reportes_similares - Find related reports",
    "ReportesController.Enviar_Respuest_caso - Agent response submission",
    "ReportesController.consultar_respuesta_agentes - Get agent responses",
    "ReportesController.GetClasesProblema - Get problem classes by type",
    "ReportesController.GetTiposProblema - Get problem types by class",
    "ReportesController.ObtenerCiudades - Get cities by department"
  ]
